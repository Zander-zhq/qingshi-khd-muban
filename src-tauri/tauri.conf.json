{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "青拾客户端",
  "version": "0.1.0",
  "identifier": "com.qingshi.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "加载中",
        "url": "/login",
        "width": 420,
        "height": 640,
        "center": true,
        "resizable": false,
        "decorations": false,
        "shadow": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ]
  }
}